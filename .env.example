# Google Gemini API Key (get from aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Resend API Key (get from resend.com/api-keys)
RESEND_API_KEY=your_resend_api_key_here

# Email address to receive the digest
EMAIL_TO=your_email@example.com

# Optional: Email sender (must be verified domain in Resend, or use onboarding@resend.dev for testing)
EMAIL_FROM=onboarding@resend.dev
